{
  "name": "@pointcut/core",
  "version": "0.0.0",
  "description": "Bundler-free, framework-free guts of Pointcut: client, models, drivers, and the Bridge.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./models": {
      "import": "./dist/models/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test"
  },
  "dependencies": {
    "launch-editor": "^2.8.1"
  }
}
