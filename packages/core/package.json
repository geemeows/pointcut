{
  "name": "@pointcut/core",
  "version": "0.2.0",
  "description": "Bundler-free, framework-free guts of Pointcut: client, models, drivers, and the Bridge.",
  "type": "module",
  "license": "MIT",
  "author": "Gazouly",
  "homepage": "https://github.com/geemeows/pointcut/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/geemeows/pointcut.git",
    "directory": "packages/core"
  },
  "bugs": "https://github.com/geemeows/pointcut/issues",
  "keywords": [
    "pointcut",
    "design-mode",
    "ai-agent",
    "devtools",
    "bridge",
    "source-stamp",
    "jump-to-source"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test"
  },
  "dependencies": {
    "launch-editor": "^2.8.1"
  }
}
